// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String    @unique
  password         String
  address          String?
  phone            String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Donation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String
  userEmail        String
  userName         String
  name             String
  type             String   // food or clothes
  quantity         Int
  description      String?
  address          String
  phone            String
  preferredTime    String?
  urgency          String   @default("normal") // normal, urgent, very-urgent
  status           String   @default("pending")
  assignedTo       String?
  photoUrl         String?
  securityCode     String
  assignedAt       DateTime?
  pickedUpAt       DateTime?
  donatedAt        DateTime?
  deliveryConfirmed Boolean  @default(false)
  deliveryNotes    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
